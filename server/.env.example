PORT=5000
NODE_ENV=production

# MongoDB Atlas URI (required for production)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/fashion-mission?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRE=7d

# Stripe (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (your Netlify URL)
CLIENT_URL=https://dynamic-eclair-b04019.netlify.app